FROM langchain/langgraph-api:3.12-bookworm

ARG NODE_MAJOR=22

USER root

# Install Node.js
RUN apt-get update && apt-get install -y \
    curl \
    build-essential \
    gnupg \
    ca-certificates \
    && mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_${NODE_MAJOR}.x nodistro main" > /etc/apt/sources.list.d/nodesource.list \
    && apt-get update \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install Docker CLI only
COPY --from=docker:cli /usr/local/bin/docker /usr/local/bin/docker

RUN npm config set registry https://registry.npmmirror.com && \
    npm config set maxsockets 50 && \
    npm config set fetch-retries 5

ENV UV_DEFAULT_INDEX=https://pypi.tuna.tsinghua.edu.cn/simple
ENV UV_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
ENV UV_NO_PROGRESS=1

ADD backend /deps/backend

RUN cd /deps/backend/packages/harness && \
    PYTHONDONTWRITEBYTECODE=1 uv pip install --system --no-cache-dir -c /api/constraints.txt -e .

ENV LANGGRAPH_CHECKPOINTER='{"path": "/deps/backend/packages/harness/deerflow/agents/checkpointer/async_provider.py:make_checkpointer"}'
ENV LANGSERVE_GRAPHS='{"lead_agent": "deerflow.agents:make_lead_agent"}'

RUN mkdir -p /api/langgraph_api /api/langgraph_runtime /api/langgraph_license && \
    touch /api/langgraph_api/__init__.py /api/langgraph_runtime/__init__.py /api/langgraph_license/__init__.py

RUN PYTHONDONTWRITEBYTECODE=1 uv pip install --system --no-cache-dir --no-deps -e /api

WORKDIR /deps/backend