--- /dev/null
+++ b/backend/tests/skills/test_skill_storage_local.py
@@ -0,0 +1,297 @@
+"""Tests for LocalSkillStorage and the SkillStorage abstraction."""
+
+from __future__ import annotations
+
+import io
+import json
+import zipfile
+from pathlib import Path
+
+import pytest
+from skills_test_helpers import reset_skill_storage, set_skill_storage
+
+from deerflow.skills.installer import SkillAlreadyExistsError
+from deerflow.skills.storage import LocalSkillStorage, get_skill_storage
+from deerflow.skills.storage.skill_storage import SkillStorage
+
+
+def _write_skill(skill_dir: Path, name: str, description: str = "Test skill") -> None:
+    skill_dir.mkdir(parents=True, exist_ok=True)
+    (skill_dir / "SKILL.md").write_text(
+        f"---\nname: {name}\ndescription: {description}\n---\n\n# {name}\n",
+        encoding="utf-8",
+    )
+
+
+def _make_skill_archive(tmp_path: Path, name: str, description: str = "Archive skill") -> Path:
+    buf = io.BytesIO()
+    with zipfile.ZipFile(buf, "w", zipfile.ZIP_DEFLATED) as zf:
+        zf.writestr(
+            f"{name}/SKILL.md",
+            f"---\nname: {name}\ndescription: {description}\n---\n\n# {name}\n",
+        )
+    archive = tmp_path / f"{name}.skill"
+    archive.write_bytes(buf.getvalue())
+    return archive
+
+
+@pytest.fixture
+def storage(tmp_path: Path) -> LocalSkillStorage:
+    return LocalSkillStorage(host_path=str(tmp_path / "skills"))
+
+
+def test_local_storage_implements_abstract_class(storage: LocalSkillStorage):
+    assert isinstance(storage, SkillStorage)
+
+
+def test_load_skills_discovers_public_and_custom(tmp_path: Path, storage: LocalSkillStorage):
+    root = storage.get_skills_root_path()
+    _write_skill(root / "public" / "p1", "p1")
+    _write_skill(root / "custom" / "c1", "c1")
+
+    skills = storage.load_skills()
+    by_name = {s.name: s for s in skills}
+
+    assert by_name["p1"].category == "public"
+    assert by_name["c1"].category == "custom"
+
+
+def test_load_skills_returns_empty_when_root_missing(tmp_path: Path):
+    storage = LocalSkillStorage(host_path=str(tmp_path / "does-not-exist"))
+    assert storage.load_skills() == []
+
+
+def test_custom_and_public_skill_exists(storage: LocalSkillStorage):
+    root = storage.get_skills_root_path()
+    _write_skill(root / "public" / "p1", "p1")
+    _write_skill(root / "custom" / "c1", "c1")
+
+    assert storage.public_skill_exists("p1") is True
+    assert storage.custom_skill_exists("c1") is True
+    assert storage.public_skill_exists("nope") is False
+    assert storage.custom_skill_exists("nope") is False
+
+
+def test_read_custom_skill_content_returns_markdown(storage: LocalSkillStorage):
+    root = storage.get_skills_root_path()
+    _write_skill(root / "custom" / "c1", "c1", description="Hello")
+
+    content = storage.read_custom_skill("c1")
+    assert "name: c1" in content
+    assert "Hello" in content
+
+
+def test_read_custom_skill_content_raises_when_missing(storage: LocalSkillStorage):
+    with pytest.raises(FileNotFoundError):
+        storage.read_custom_skill("absent")
+
+
+def test_delete_custom_skill_removes_directory(storage: LocalSkillStorage):
+    root = storage.get_skills_root_path()
+    _write_skill(root / "custom" / "c1", "c1")
+
+    storage.delete_custom_skill("c1")
+    assert not storage.custom_skill_exists("c1")
+
+
+def test_delete_custom_skill_rejects_builtin(storage: LocalSkillStorage):
+    root = storage.get_skills_root_path()
+    _write_skill(root / "public" / "builtin", "builtin")
+
+    with pytest.raises(ValueError):
+        storage.delete_custom_skill("builtin")
+
+
+def test_install_skill_from_archive_creates_custom_skill(tmp_path: Path, storage: LocalSkillStorage):
+    archive = _make_skill_archive(tmp_path, "from-archive")
+
+    result = storage.install_skill_from_archive(archive)
+    assert result["success"] is True
+    assert result["skill_name"] == "from-archive"
+    assert storage.custom_skill_exists("from-archive")
+
+
+def test_install_skill_from_archive_rejects_duplicate(tmp_path: Path, storage: LocalSkillStorage):
+    archive = _make_skill_archive(tmp_path, "dupe")
+    storage.install_skill_from_archive(archive)
+    with pytest.raises(SkillAlreadyExistsError):
+        storage.install_skill_from_archive(archive)
+
+
+def test_install_skill_from_archive_validates_extension(tmp_path: Path, storage: LocalSkillStorage):
+    bad = tmp_path / "not-a-skill.zip"
+    bad.write_bytes(b"PK\x03\x04")
+    with pytest.raises(ValueError, match=".skill extension"):
+        storage.install_skill_from_archive(bad)
+
+
+def test_install_skill_from_archive_missing_file(tmp_path: Path, storage: LocalSkillStorage):
+    with pytest.raises(FileNotFoundError):
+        storage.install_skill_from_archive(tmp_path / "nope.skill")
+
+
+def test_history_round_trip(storage: LocalSkillStorage):
+    root = storage.get_skills_root_path()
+    _write_skill(root / "custom" / "c1", "c1")
+
+    storage.append_history("c1", {"action": "a", "n": 1})
+    storage.append_history("c1", {"action": "b", "n": 2})
+
+    history = storage.read_history("c1")
+    assert [h["action"] for h in history[-2:]] == ["a", "b"]
+    # Each line is valid JSON with a timestamp.
+    raw_path = storage.get_skills_root_path() / "custom" / ".history" / "c1.jsonl"
+    for line in raw_path.read_text().splitlines():
+        if line.strip():
+            assert "ts" in json.loads(line)
+
+
+def test_get_container_root_default(storage: LocalSkillStorage):
+    assert storage.get_container_root() == "/mnt/skills"
+
+
+def test_get_container_root_custom(tmp_path: Path):
+    storage = LocalSkillStorage(host_path=str(tmp_path / "skills"), container_path="/custom/root")
+    assert storage.get_container_root() == "/custom/root"
+
+
+def test_singleton_set_and_reset(tmp_path: Path):
+    custom = LocalSkillStorage(host_path=str(tmp_path / "skills"))
+    set_skill_storage(custom)
+    try:
+        assert get_skill_storage() is custom
+    finally:
+        reset_skill_storage()
+
+
+# ---------------------------------------------------------------------------
+# write_custom_skill
+# ---------------------------------------------------------------------------
+
+
+def test_write_custom_skill_creates_file(storage: LocalSkillStorage):
+    root = storage.get_skills_root_path()
+    _write_skill(root / "custom" / "c1", "c1")
+
+    storage.write_custom_skill("c1", "SKILL.md", "---\nname: c1\ndescription: updated\n---\n")
+    content = (root / "custom" / "c1" / "SKILL.md").read_text(encoding="utf-8")
+    assert "updated" in content
+
+
+def test_write_custom_skill_creates_support_file(storage: LocalSkillStorage):
+    root = storage.get_skills_root_path()
+    _write_skill(root / "custom" / "c1", "c1")
+
+    storage.write_custom_skill("c1", "references/doc.md", "# doc")
+    assert (root / "custom" / "c1" / "references" / "doc.md").read_text(encoding="utf-8") == "# doc"
+
+
+# ---------------------------------------------------------------------------
+# delete_custom_skill with history_meta
+# ---------------------------------------------------------------------------
+
+
+def test_delete_custom_skill_with_history_meta_writes_history(storage: LocalSkillStorage):
+    root = storage.get_skills_root_path()
+    _write_skill(root / "custom" / "c1", "c1")
+
+    storage.delete_custom_skill("c1", history_meta={"action": "delete", "author": "test"})
+    assert not storage.custom_skill_exists("c1")
+
+    history = storage.read_history("c1")
+    assert any(h["action"] == "delete" for h in history)
+
+
+# ---------------------------------------------------------------------------
+# read_history edge cases
+# ---------------------------------------------------------------------------
+
+
+def test_read_history_returns_empty_when_no_file(storage: LocalSkillStorage):
+    root = storage.get_skills_root_path()
+    _write_skill(root / "custom" / "c1", "c1")
+
+    assert storage.read_history("c1") == []
+
+
+# ---------------------------------------------------------------------------
+# ensure_custom_skill_is_editable
+# ---------------------------------------------------------------------------
+
+
+def test_ensure_custom_skill_is_editable_passes_for_custom(storage: LocalSkillStorage):
+    root = storage.get_skills_root_path()
+    _write_skill(root / "custom" / "c1", "c1")
+    storage.ensure_custom_skill_is_editable("c1")  # must not raise
+
+
+def test_ensure_custom_skill_is_editable_raises_for_public(storage: LocalSkillStorage):
+    root = storage.get_skills_root_path()
+    _write_skill(root / "public" / "builtin", "builtin")
+
+    with pytest.raises(ValueError, match="built-in"):
+        storage.ensure_custom_skill_is_editable("builtin")
+
+
+def test_ensure_custom_skill_is_editable_raises_when_missing(storage: LocalSkillStorage):
+    with pytest.raises(FileNotFoundError):
+        storage.ensure_custom_skill_is_editable("ghost")
+
+
+# ---------------------------------------------------------------------------
+# validate_skill_markdown_content
+# ---------------------------------------------------------------------------
+
+
+def test_validate_skill_markdown_content_accepts_valid(storage: LocalSkillStorage):
+    content = "---\nname: my-skill\ndescription: A skill.\n---\n\n# my-skill\n"
+    SkillStorage.validate_skill_markdown_content("my-skill", content)  # must not raise
+
+
+def test_validate_skill_markdown_content_rejects_name_mismatch(storage: LocalSkillStorage):
+    content = "---\nname: other-skill\ndescription: A skill.\n---\n\n# other-skill\n"
+    with pytest.raises(ValueError, match="must match"):
+        SkillStorage.validate_skill_markdown_content("my-skill", content)
+
+
+def test_validate_skill_markdown_content_rejects_missing_frontmatter(storage: LocalSkillStorage):
+    with pytest.raises(ValueError):
+        SkillStorage.validate_skill_markdown_content("my-skill", "no frontmatter here")
+
+
+# ---------------------------------------------------------------------------
+# ensure_safe_support_path
+# ---------------------------------------------------------------------------
+
+
+def test_ensure_safe_support_path_returns_resolved_path(storage: LocalSkillStorage):
+    root = storage.get_skills_root_path()
+    _write_skill(root / "custom" / "c1", "c1")
+
+    result = storage.ensure_safe_support_path("c1", "references/doc.md")
+    expected = (root / "custom" / "c1" / "references" / "doc.md").resolve()
+    assert result == expected
+
+
+def test_ensure_safe_support_path_rejects_disallowed_subdir(storage: LocalSkillStorage):
+    root = storage.get_skills_root_path()
+    _write_skill(root / "custom" / "c1", "c1")
+
+    with pytest.raises(ValueError, match="must live under"):
+        storage.ensure_safe_support_path("c1", "secrets/password.txt")
+
+
+def test_ensure_safe_support_path_rejects_traversal(storage: LocalSkillStorage):
+    root = storage.get_skills_root_path()
+    _write_skill(root / "custom" / "c1", "c1")
+
+    with pytest.raises(ValueError, match="traversal|parent-directory"):
+        storage.ensure_safe_support_path("c1", "references/../../../etc/passwd")
+
+
+def test_ensure_safe_support_path_rejects_absolute_path(storage: LocalSkillStorage):
+    root = storage.get_skills_root_path()
+    _write_skill(root / "custom" / "c1", "c1")
+
+    with pytest.raises(ValueError, match="relative"):
+        storage.ensure_safe_support_path("c1", "/etc/passwd")
