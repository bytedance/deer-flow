@@ -0,0 +1,21 @@
+"""Test-only helpers for the SkillStorage singleton.
+
+Production code never resets or injects the singleton; these helpers exist
+only so tests can swap in a per-test ``LocalSkillStorage`` rooted at a
+``tmp_path`` skills directory and clean up between tests.
+"""
+
+from __future__ import annotations
+
+from deerflow.skills import storage as _storage_module
+from deerflow.skills.storage import SkillStorage
+
+
+def reset_skill_storage() -> None:
+    """Clear the cached singleton without any cleanup."""
+    _storage_module._default_skill_storage = None
+
+
+def set_skill_storage(storage: SkillStorage) -> None:
+    """Inject a custom ``SkillStorage`` instance."""
+    _storage_module._default_skill_storage = storage
