{
  "mcpServers": {
    "filesystem": {
      "enabled": true,
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/path/to/allowed/files"],
      "env": {},
      "description": "Provides filesystem access within allowed directories"
    },
    "github": {
      "enabled": true,
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "$GITHUB_TOKEN"
      },
      "description": "GitHub MCP server for repository operations"
    },
    "postgres": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres", "postgresql://localhost/mydb"],
      "env": {},
      "description": "PostgreSQL database access"
    },
    "my-sse-server": {                                                                                                                                       
        "type": "sse",                                                                                                                                         
        "url": "https://api.example.com/mcp",                                                                                                                  
        "headers": {                                                                                                                                           
          "Authorization": "Bearer $API_TOKEN",                                                                                                                
          "X-Custom-Header": "value"                                                                                                                           
        },
        "oauth": {
          "enabled": true,
          "token_url": "https://auth.example.com/oauth/token",
          "grant_type": "client_credentials",
          "client_id": "$MCP_OAUTH_CLIENT_ID",
          "client_secret": "$MCP_OAUTH_CLIENT_SECRET",
          "scope": "mcp.read mcp.write",
          "audience": "https://api.example.com",
          "refresh_skew_seconds": 60
        }
    },
    "my-http-server": {                                                                                                                                       
        "type": "http",                                                                                                                                         
        "url": "https://api.example.com/mcp",                                                                                                                  
        "headers": {                                                                                                                                           
          "Authorization": "Bearer $API_TOKEN",                                                                                                                
          "X-Custom-Header": "value"                                                                                                                           
        },
        "oauth": {
          "enabled": true,
          "token_url": "https://auth.example.com/oauth/token",
          "grant_type": "client_credentials",
          "client_id": "$MCP_OAUTH_CLIENT_ID",
          "client_secret": "$MCP_OAUTH_CLIENT_SECRET"
        }
    },
    "zotero": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "zotero-mcp-server"],
      "env": {
        "ZOTERO_API_KEY": "$ZOTERO_API_KEY",
        "ZOTERO_USER_ID": "$ZOTERO_USER_ID"
      },
      "description": "Zotero reference manager for academic literature management — search, add, organize references and generate citations"
    },
    "jupyter": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-jupyter"],
      "env": {
        "JUPYTER_TOKEN": "$JUPYTER_TOKEN",
        "JUPYTER_URL": "http://localhost:8888"
      },
      "description": "JupyterLab integration for interactive scientific computing — execute notebook cells, inspect variables, run experiments"
    },
    "arxiv": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "arxiv-mcp-server"],
      "env": {},
      "description": "arXiv paper search and retrieval — search papers, get abstracts, download PDFs for academic research"
    },
    "semantic-scholar": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "semantic-scholar-mcp-server"],
      "env": {
        "SEMANTIC_SCHOLAR_API_KEY": "$SEMANTIC_SCHOLAR_API_KEY"
      },
      "description": "Semantic Scholar API for paper search, citation analysis, author profiles, and citation graph traversal"
    },
    "overleaf": {
      "enabled": false,
      "type": "http",
      "url": "",
      "description": "Overleaf LaTeX collaboration (requires Overleaf Server Pro or community API)"
    }
  },
  "skills": {
    "pdf-processing": {
      "enabled": true
    },
    "frontend-design": {
      "enabled": true
    }
  }
}
